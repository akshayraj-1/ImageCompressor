<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Img Compressor</title>
    <link rel='stylesheet' href='/css/style.css' />
  </head>
  <body>
  <%- include('partials/navbar.ejs') %>
  <%- include('partials/background.ejs') %>
  <div class="relative flex flex-col items-center justify-center h-full w-full py-14 px-6 sm:px-9">
    <h1 class="text-[2.5rem] text-textPrimary text-center font-semibold"><span class="text-accent">Online</span> Image Compressor</h1>
    <p class="text-textSecondary text-center font-normal py-3">Compress images with a single click, reduce image size <span class="">without losing image quality.</span></p>

    <div id="drop-area" class="select-none w-full sm:max-w-[70%] sm:mx-0 mx-6 bg-secondary my-7 px-6 py-3 rounded-2xl border border-textSecondary border-dashed shadow-mainCard">
      <form id="upload-form" class="flex flex-col items-center justify-center py-10"
            action="/compress" method="post" enctype="multipart/form-data">
        <input id="inp-image" type="file" accept="image/jpg, image/jpeg, image/png" name="image" hidden required/>
        <img class="size-12" src="/assets/add.svg" alt="Select Image">
        <button id="btn-upload" class="text-white text-md font-medium mt-9 py-3 px-7 rounded-full bg-gradient-to-br from-accentLight to-accent shadow-primaryButton"><i class="ri-upload-2-line me-2"></i>Upload Image</button>
        <span class="text-sm text-textSecondary mt-4">or drop an image</span>
      </form>
      <div id="image-view">

      </div>
    </div>
  </div>
  <script type="text/javascript" src="/js/home.js"></script>
  </body>
</html>
